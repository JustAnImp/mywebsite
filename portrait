<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portrait — Eva Mann</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    /* ── TOKENS ─────────────────────────────── */
    :root {
      --creme:      #f7f0eb;
      --creme-dark: #efe6de;
      --nav-bg:     #1e1c1a;
      --nav-hover:  #2e2b28;
      --rot:        #8b1a1a;
      --rot-logo:   #913521;
      --schwarz:    #1a1a1a;
      --grau:       #6b6460;
      --linie:      #d4ccc0;
      --weiss:      #f5f0e8;

      --font-display: 'Cormorant Garamond', Georgia, serif;
      --font-body:    'Jost', sans-serif;
      --max-w: 1200px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      background: var(--creme);
      color: var(--schwarz);
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 16px;
      line-height: 1.7;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }

    /* ══════════════════════════════════════════
       HEADER
    ══════════════════════════════════════════ */
    .site-header { position: sticky; top: 0; z-index: 100; }

    .logo-bar {
      background: var(--creme);
      padding: 1.4rem 2rem 1.2rem;
      text-align: center;
      border-bottom: 1px solid var(--linie);
    }
    .logo-bar a { display: inline-block; }
    .logo-name {
      font-family: var(--font-display);
      font-size: 2.1rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--rot-logo);
      display: block;
      line-height: 1.15;
      transition: color 0.2s;
    }
    .logo-bar a:hover .logo-name { opacity: 0.8; }
    .logo-sub {
      font-family: var(--font-body);
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      color: var(--grau);
      display: block;
      margin-top: 0.2rem;
    }

    .nav-bar { background: var(--nav-bg); }
    .nav-desktop { max-width: var(--max-w); margin: 0 auto; padding: 0 1rem; }
    .nav-list {
      list-style: none;
      display: flex;
      align-items: stretch;
      justify-content: center;
      flex-wrap: wrap;
    }
    .nav-list > li { position: relative; }
    .nav-list > li > a {
      display: flex;
      align-items: center;
      padding: 0.85rem 0.85rem;
      font-family: var(--font-body);
      font-size: 0.73rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--weiss);
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
    }
    .nav-list > li > a:hover { background: var(--nav-hover); color: #e8c8a0; }
    .nav-list > li > a.active {
      background: var(--nav-hover);
      color: #e8c8a0;
      box-shadow: inset 0 -2px 0 var(--rot);
    }

    .hamburger {
      display: none;
      background: none; border: none; cursor: pointer;
      padding: 0.85rem 1.2rem;
      flex-direction: column; gap: 5px;
    }
    .hamburger span {
      display: block; width: 22px; height: 1.5px;
      background: var(--weiss); transition: all 0.28s;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    .mobile-drawer { display: none; background: var(--nav-bg); border-top: 1px solid #2e2b28; }
    .mobile-drawer.open { display: block; }
    .mobile-drawer > ul { list-style: none; }
    .mobile-drawer > ul > li { border-bottom: 1px solid #2a2826; }
    .mobile-drawer > ul > li > a {
      display: block; width: 100%;
      padding: 0.9rem 1.5rem;
      font-size: 0.76rem; font-weight: 400;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--weiss); transition: color 0.18s;
    }
    .mobile-drawer > ul > li > a:hover { color: #e8c8a0; }

    /* ══════════════════════════════════════════
       PORTRAIT SLIDESHOW
    ══════════════════════════════════════════ */
    .portrait-slideshow-wrap {
      max-width: var(--max-w);
      margin: 3rem auto 0;
      padding: 0 3rem;
    }

    .portrait-slideshow {
      position: relative;
      width: 100%;
      aspect-ratio: 3/2;
      overflow: hidden;
      background: var(--schwarz);
    }

    .portrait-slideshow .slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 1.2s ease-in-out;
    }
    .portrait-slideshow .slide.active { opacity: 1; }
    .portrait-slideshow .slide img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
    }
    .portrait-slideshow .slide-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display);
      font-size: 0.85rem; color: rgba(255,255,255,0.2);
      letter-spacing: 0.15em; text-transform: uppercase;
    }

    .portrait-slideshow .slide-dots {
      position: absolute;
      bottom: 1rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 0.5rem;
      z-index: 10;
    }
    .portrait-slideshow .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: rgba(255,255,255,0.35);
      cursor: pointer;
      border: none; padding: 0;
      transition: background 0.3s, transform 0.3s;
    }
    .portrait-slideshow .dot.active {
      background: rgba(255,255,255,0.9);
      transform: scale(1.3);
    }

    /* ══════════════════════════════════════════
       BIOGRAPHIE
    ══════════════════════════════════════════ */
    .biographie {
      max-width: var(--max-w);
      margin: 3.5rem auto 0;
      padding: 0 3rem;
    }

    .section-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rot-logo);
      margin-bottom: 1.2rem;
    }

    .bio-text {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 300;
      line-height: 1.75;
      color: var(--schwarz);
      max-width: 72ch;
      /*
        TEXT EINSETZEN:
        Einfach den Platzhaltertext unten ersetzen.
        Absätze mit <p> trennen.
      */
    }
    .bio-text p + p { margin-top: 1.2em; }

    /* ══════════════════════════════════════════
       ARTIKEL-KACHELN
    ══════════════════════════════════════════ */
    .artikel-section {
      max-width: var(--max-w);
      margin: 3.5rem auto 5rem;
      padding: 0 3rem;
    }

    .artikel-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .artikel-kachel {
      cursor: pointer;
      overflow: hidden;
      aspect-ratio: 3/4;
      background: var(--creme-dark);
      position: relative;
    }
    .artikel-kachel img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .artikel-kachel:hover img { transform: scale(1.04); }

    .artikel-kachel-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display);
      font-size: 0.75rem; color: var(--linie);
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 1rem; text-align: center;
    }

    /* Hover-Overlay */
    .artikel-kachel::after {
      content: '↗';
      position: absolute;
      inset: 0;
      background: rgba(145, 53, 33, 0.15);
      color: white;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .artikel-kachel:hover::after { opacity: 1; }

    /* ══════════════════════════════════════════
       LIGHTBOX
    ══════════════════════════════════════════ */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: rgba(0,0,0,0.92);
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .lightbox.open { display: flex; }

    .lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      object-fit: contain;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }

    .lightbox-close {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
      background: none;
      border: none;
      color: white;
      font-size: 2rem;
      cursor: pointer;
      line-height: 1;
      opacity: 0.7;
      transition: opacity 0.2s;
    }
    .lightbox-close:hover { opacity: 1; }

    /* ── FOOTER ─────────────────────────────── */
    footer { border-top: 1px solid var(--linie); margin-top: auto; }
    .footer-inner {
      max-width: var(--max-w); margin: 0 auto; padding: 2rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1rem; flex-wrap: wrap;
    }
    .footer-logo { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--rot-logo); }
    .footer-copy { font-size: 0.72rem; color: var(--grau); }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--grau); transition: color 0.2s; }
    .footer-links a:hover { color: var(--rot); }
    .footer-linkedin { display: flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; color: var(--grau); transition: color 0.2s; }
    .footer-linkedin:hover { color: var(--rot); }
    .footer-linkedin svg { width: 15px; height: 15px; fill: currentColor; }

    /* ── RESPONSIVE ─────────────────────────── */
    @media (max-width: 900px) {
      .nav-desktop { display: none; }
      .hamburger { display: flex; }
      .nav-bar { display: flex; justify-content: flex-end; }

      .portrait-slideshow-wrap,
      .biographie,
      .artikel-section { padding: 0 1.5rem; }

      .artikel-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 500px) {
      .logo-name { font-size: 1.65rem; }
      .footer-inner { flex-direction: column; align-items: flex-start; }
      .artikel-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
